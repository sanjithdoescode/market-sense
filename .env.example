# Application Settings
NODE_ENV=development
PORT=5001

# Client / Frontend Settings (Vite)
# For the frontend API requests, set this to the backend server URL:
VITE_API_BASE_URL=http://localhost:5001/api
CLIENT_ORIGIN=http://localhost:5173

# Database Settings
MONGO_URI=mongodb://localhost:27017/business_gap_finder

# Google Places / Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_API_TIMEOUT_MS=12000
GOOGLE_PLACES_MAX_COMPETITORS=10

# Mistral AI API
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
MISTRAL_MODEL=mistral-medium-2508
MISTRAL_TIMEOUT_MS=150000
